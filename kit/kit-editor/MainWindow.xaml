<Window x:Class="KitEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit"
        Title="Co2H Kit Editor" Width="1100" Height="700"
        Icon="pack://application:,,,/kit-icon.ico"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterScreen"
        FontFamily="Consolas"
        WindowStyle="None"
        ResizeMode="CanResize"
        BorderBrush="#FFFF0000"
        BorderThickness="1">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="28"
                            GlassFrameThickness="0"
                            CornerRadius="0"
                            UseAeroCaptionButtons="False"
                            ResizeBorderThickness="4"/>
    </shell:WindowChrome.WindowChrome>


    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="28"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ============ Custom title bar ============ -->
        <Border Grid.Row="0" Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="True">
                <!-- Кнопки закрытия/развернуть/свернуть. Нужен IsHitTestVisibleInChrome=True
                     иначе WindowChrome перехватит клик как перетаскивание окна. -->
                <Button DockPanel.Dock="Right" x:Name="btnClose"
                        Style="{StaticResource TitleBarCloseButton}"
                        Content="✕" Click="OnTitleClose"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                <Button DockPanel.Dock="Right" x:Name="btnMax"
                        Style="{StaticResource TitleBarButton}"
                        Content="▢" Click="OnTitleMaximize"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                <Button DockPanel.Dock="Right" x:Name="btnMin"
                        Style="{StaticResource TitleBarButton}"
                        Content="—" Click="OnTitleMinimize"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"/>

                <!-- Заголовок (область для перетаскивания) -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="pack://application:,,,/kit-icon.ico"
                           Width="16" Height="16"
                           Margin="8,0,6,0"/>
                    <TextBlock Text="Co2H Kit Editor"
                               Foreground="{StaticResource AccentBrush}"
                               FontFamily="Consolas" FontSize="12" FontWeight="Bold"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="6,4">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Click="OnNew" Margin="0,0,4,0" ToolTip="New template">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{StaticResource Icon_New}" Width="16" Height="16" Margin="0,0,5,0"/>
                            <TextBlock Text="New" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Click="OnOpen" Margin="0,0,4,0" ToolTip="Open file">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{StaticResource Icon_Open}" Width="16" Height="16" Margin="0,0,5,0"/>
                            <TextBlock Text="Open" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Click="OnSave" Margin="0,0,4,0" ToolTip="Save file">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{StaticResource Icon_Save}" Width="16" Height="16" Margin="0,0,5,0"/>
                            <TextBlock Text="Save" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Click="OnReload" Margin="0,0,4,0" ToolTip="Reload from disk">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{StaticResource Icon_Reload}" Width="16" Height="16" Margin="0,0,5,0"/>
                            <TextBlock Text="Reload" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Rectangle Width="1" Fill="{StaticResource BorderBrush}" Margin="8,2"/>
                    <Button Click="OnCompile" Margin="4,0,0,0" FontWeight="Bold" ToolTip="Compile via build_all.bat">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{StaticResource Icon_Compile}" Width="16" Height="16" Margin="0,0,5,0"/>
                            <TextBlock Text="Compile" VerticalAlignment="Center" Foreground="#FF00FF41"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                <TextBlock DockPanel.Dock="Right" x:Name="tbFileName"
                           Text="no file" Foreground="{StaticResource AccentDimBrush}"
                           VerticalAlignment="Center" HorizontalAlignment="Right"
                           FontSize="11"/>
            </DockPanel>
        </Border>

        <!-- Main area: tree + editor -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left panel: template tree -->
            <Border Grid.Column="0" Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text=" TEMPLATES"
                               Foreground="{StaticResource HeaderBrush}"
                               FontSize="11" FontWeight="Bold"
                               Padding="8,6,0,4"/>
                    <TreeView x:Name="tvTemplates" Background="Transparent"
                              BorderThickness="0" Padding="4,0"
                              SelectedItemChanged="OnTemplateSelected"/>
                </DockPanel>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="3" Background="{StaticResource BorderBrush}"
                          HorizontalAlignment="Center" VerticalAlignment="Stretch"/>

            <!-- Code editor: AvalonEdit -->
            <Border Grid.Column="2" Background="{StaticResource BgBrush}" Padding="0">
                <avalon:TextEditor x:Name="tbEditor"
                                   Background="#FF050505"
                                   Foreground="{StaticResource TextBrush}"
                                   LineNumbersForeground="{StaticResource AccentDimBrush}"
                                   ShowLineNumbers="True"
                                   FontFamily="Consolas" FontSize="13"
                                   WordWrap="False"
                                   Padding="6,4"
                                   HorizontalScrollBarVisibility="Auto"
                                   VerticalScrollBarVisibility="Auto"/>
            </Border>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="3" Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="8,3">
            <DockPanel>
                <TextBlock x:Name="tbStatus" Text="Ready"
                           Foreground="{StaticResource AccentDimBrush}" FontSize="11"/>
                <TextBlock x:Name="tbArch" DockPanel.Dock="Right"
                           Text="x64 + x86" HorizontalAlignment="Right"
                           Foreground="{StaticResource AccentDimBrush}" FontSize="11"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
